---
layout: page
---
<article class="publication-page">
  <header class="pub-hero">
    <h1 class="pub-title">{{ page.title }}</h1>

    {% if page.authors %}
      <div class="pub-authors">
        {% if page.authors.size %}
          {% for author in page.authors %}
            {% if author.url %}
              <a href="{{ author.url }}">{{ author.name }}</a>
            {% else %}
              {{ author.name }}
            {% endif %}
            {% unless forloop.last %}, {% endunless %}
          {% endfor %}
        {% else %}
          {{ page.authors }}
        {% endif %}
      </div>
    {% endif %}

    {% if page.venue or page.year %}
      <div class="pub-venue">
        {% if page.venue %}{{ page.venue }}{% endif %}{% if page.venue and page.year %} À {% endif %}{% if page.year %}{{ page.year }}{% endif %}
      </div>
    {% endif %}

    {% if page.links %}
      <div class="pub-links">
        {% for link in page.links %}
          <a class="btn btn-sm z-depth-0" href="{{ link.url }}">{{ link.label }}</a>
        {% endfor %}
      </div>
    {% endif %}

    {% if page.logos %}
      <div class="pub-logos">
        {% for logo in page.logos %}
          {% if logo.url %}
            <a href="{{ logo.url }}">
              <img src="{{ logo.image }}" alt="{{ logo.alt }}">
            </a>
          {% else %}
            <img src="{{ logo.image }}" alt="{{ logo.alt }}">
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </header>

  {% if page.abstract %}
    <section class="pub-abstract">
      <h2>Abstract</h2>
      {{ page.abstract | markdownify }}
    </section>
  {% endif %}

  {% if page.teaser %}
    <div class="pub-teaser">
      {% if page.teaser contains '://' %}
        <img class="img-fluid rounded z-depth-1" src="{{ page.teaser }}" alt="{{ page.title }}">
      {% else %}
        {% capture pub_sizes %}(min-width: {{ site.max_width }}) {{ site.max_width }}, 95vw{% endcapture %}
        {% include figure.liquid
          loading="eager"
          path=page.teaser
          class="img-fluid rounded z-depth-1"
          sizes=pub_sizes
          alt=page.title
        %}
      {% endif %}
      {% if page.teaser_caption %}
        <p class="pub-teaser-caption">{{ page.teaser_caption }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if page.bibtex %}
    <section class="pub-bibtex">
      <h2>BibTeX</h2>
      {% highlight bibtex %}
      {{- page.bibtex | strip -}}
      {% endhighlight %}
    </section>
  {% endif %}

  {% if page.highlights %}
    <section class="pub-highlights">
      <h2>Highlights</h2>
      <ul>
        {% for item in page.highlights %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </section>
  {% endif %}

  {% if content and content != '' %}
    <section class="pub-content">
      {{ content }}
    </section>
  {% endif %}
</article>